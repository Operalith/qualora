# Qualora local development defaults.
# These values are for local Docker Compose only and must not be reused in production.

QUALORA_API_URL=http://localhost:8080
QUALORA_API_PORT=8080
QUALORA_TARGET_URL=https://example.com
QUALORA_ALLOWED_HOST=example.com
QUALORA_API_SMOKE_URL=http://mock-api:8080
QUALORA_API_SMOKE_OPENAPI_URL=http://mock-api:8080/openapi.json
QUALORA_API_SMOKE_ALLOWED_HOST=mock-api
MOCK_API_PORT=18081

POSTGRES_USER=qualora
POSTGRES_PASSWORD=qualora
POSTGRES_DB=qualora

MINIO_ROOT_USER=qualora
MINIO_ROOT_PASSWORD=qualora-dev-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=qualora-evidence
