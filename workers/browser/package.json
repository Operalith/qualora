{
  "name": "@operalith/qualora-worker-browser",
  "version": "0.6.0-alpha",
  "private": true,
  "description": "Qualora browser worker for Playwright smoke checks",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
