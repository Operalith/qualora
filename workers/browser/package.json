  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.730.0",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
